PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
FRONTEND_ORIGIN=http://localhost:5173

# Required for real WeChat mini-program OpenID login.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# Optional local-only fallback for exercising the backend login flow without real WeChat credentials.
# WECHAT_DEV_OPENID=dev-openid-001
# WECHAT_DEV_UNIONID=

# Use a long random value in production.
AUTH_TOKEN_SECRET=change-me-in-production
AUTH_TOKEN_TTL_SECONDS=604800

FREE_DAILY_QUOTA=3
REWARDED_AD_BONUS=3

# Portrait matting: highest = BiRefNet portrait / BRIA first, U2Net fallback.
PORTRAIT_MATTING_QUALITY=highest
PORTRAIT_MATTING_MODELS=birefnet-portrait,bria-rmbg,u2net_human_seg,u2netp
PORTRAIT_ALPHA_FOREGROUND_THRESHOLD=245
PORTRAIT_ALPHA_BACKGROUND_THRESHOLD=8
PORTRAIT_ALPHA_ERODE_SIZE=4

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
ENABLE_OPENAI_IMAGE_EDIT=false
